{
    "height": 40, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "modules-left": ["custom/launcher", "cpu", "memory", "custom/spotify", "battery"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [
        "tray",
        "bluetooth",
        "network",
        "pulseaudio",
        "backlight",
        "clock",
        "custom/power-menu"
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": " у°®Ҝ",
            "default": "у°Ҡ "
        }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "interval": 60,
        "align": 0,
        "rotate": 0,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%d %b, %I:%M %p}",
        "format-alt": "{:%a %b %d, %G}"
    },
    "bluetooth": {
        "format": "пҠ”",
        "on-click": "blueberry"
    },
    "cpu": {
        "interval": 10,
        "format": "пҮҫ  {}%",
        "max-length": 10,
        "on-click": ""
    },
    "memory": {
        "interval": 30,
        "format": "пҲҖ  {}%",
        "format-alt": "пҲҖ {used:0.1f}GB",
        "max-length": 10
    },
    "backlight": {
        "device": "eDP-1",
        "format": "{icon}",
        "tooltip-format": "{percent}",
        "format-icons": ["уұ©Һ ", "уұ©Ҹ ", "уұ©җ ", "уұ©‘ ", "уұ©’ ", "уұ©“ ", "уұ©” ", "уұ©• ", "уұ©– ", "у°ӣЁ "],
        "on-scroll-up": "~/.config/waybar/scripts/brightness.sh --inc",
        "on-scroll-down": "~/.config/waybar/scripts/brightness.sh --dec"
    },
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "у°ҲҒ ",
        "format-disconnected": "у°–Ә",
        "tooltip-format": "{essid}",
        "on-click": "kitty nmtui",
        "format-icons": ["у°ӨҜ", "у°Өҹ", "у°Өў", "у°ӨҘ", "у°ӨЁ"]
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "пӘҖ",
        "format-icons": {
            "default": ["пҖҰ", "пҖ§", "у°•ҫ"]
        },
        "on-click": "pavucontrol &",
        "on-click-right": "pamixer -t",
        "scroll-step": 5,
        "on-scroll-up": "~/.config/waybar/scripts/volume.sh --inc",
        "on-scroll-down": "~/.config/waybar/scripts/volume.sh --dec"
    },
    "battery": {
        "interval": 60,
        "align": 0,
        "rotate": 0,
        "full-at": 100,
        "design-capacity": false,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "пғ§ {capacity}%",
        "format-plugged": "пҮҰ  {capacity}%",
        "format-full": "{icon}  Full",
        "format-alt": "{icon}  {time}",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"],
        "format-time": "{H}h {M}min",
        "tooltip": true
    },
    "custom/weather": {
        "exec": "python3 ~/.config/waybar/scripts/weather.py",
        "restart-interval": 300,
        "return-type": "json"
    },
    "custom/spotify": {
        "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py --player spotify",
        "format": "пҶј  {}",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "custom/power-menu": {
        "format": " вҸ» ",
        "on-click": "~/.config/rofi/scripts/powermenu"
    },
    "custom/launcher": {
        "format": "пҢғ ",
        "on-click": "~/.config/rofi/scripts/launcher"
    }
}
